## PROVIDER — choose "groq" (fast, free cloud) or "ollama" (local, slow)
PROVIDER=groq

## GROQ Config (free 14,400 requests/day at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

## Ollama Config (used if PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

## Weather API (free at openweathermap.org) — optional, falls back to mock data
WEATHER_API_KEY=your_openweather_api_key_here

## Web Search (free at tavily.com — 1000 searches/month) — optional
TAVILY_API_KEY=your_tavily_api_key_here

## Web server port (server.js)
PORT=3000
